# Resend — sends the inquiry email notification (server-side via /api/contact).
# Get a free API key at https://resend.com (sign up with the address you want
# the alerts to arrive at). Without a verified domain, the default sender only
# delivers to your own Resend account email — which is fine for notifications.
RESEND_API_KEY=
# Optional: a verified-domain sender, e.g. "Looping Ai <hello@yourdomain.com>".
RESEND_FROM=

# Optional: salt for hashing client IPs used in spam/rate-limit accounting.
# Any random string. Only a hash of the IP is ever stored, never the raw IP.
IP_HASH_SALT=

# Admin (optional) — password for the protected /admin inquiries view.
# When unset, /admin is disabled (returns 404). When set, /admin uses HTTP Basic
# auth: any username, password = this value. Use a long random string.
ADMIN_PASSWORD=

# Postgres (optional) — persist inquiries to a DB.
# On Vercel: Storage → Marketplace → Neon (Postgres); the integration injects
# POSTGRES_URL or DATABASE_URL automatically (the app accepts either).
# When set, each inquiry is saved to an "inquiries" table (auto-created).
POSTGRES_URL=
