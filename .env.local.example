# Web3Forms access key — get a free key at https://web3forms.com
# Copy this file to .env.local and fill in your key.
# Server-only (NOT exposed to the browser): the /api/contact route reads it.
WEB3FORMS_KEY=your-web3forms-access-key

# Postgres (optional) — persist inquiries to a DB.
# On Vercel: Storage tab → create a Postgres store; POSTGRES_URL is injected
# automatically. Locally: paste a Vercel Postgres / Neon connection string.
# When set, each inquiry is saved to an "inquiries" table (auto-created).
POSTGRES_URL=
